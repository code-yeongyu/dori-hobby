# deps
node_modules/
.pnpm-store/

# build
dist/
build/
.turbo/
.cache/
*.tsbuildinfo

# env
.env
.env.*
!.env.example

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# test artifacts
test-results/
playwright-report/
.playwright/
.playwright-mcp/
/dori-ui-*.png

# stray root lockfiles (each package has its own)
/bun.lock
/pnpm-lock.yaml
/pnpm-workspace.yaml

# editors
.vscode/
.idea/

# ROMS / BIOS — never commit
/nds/*.nds
/nds/*.rom
/nds/*.zip
/nds/*.7z
# DeSmuME auto-loads <rom-basename>.dct from this dir; it's generated by
# the emulator entrypoint and never hand-edited, so don't track it.
/nds/*.dct
/bios/

# recordings
/recordings/*
!/recordings/.gitkeep

# OMO metadata
.omo/
