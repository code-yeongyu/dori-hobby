{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"verbatimModuleSyntax": true,
		"noFallthroughCasesInSwitch": true,
		"skipLibCheck": true,
		"types": ["node", "vitest/globals"]
	},
	"include": ["extensions/**/*.ts", "test/**/*.ts"]
}
