{
  "name": "dori-hobby-web-ui",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "start": "bun run src/server/index.ts",
    "build:client": "bun build src/client/App.tsx --outdir dist --target browser --jsx-import-source react --format esm",
    "test": "vitest run",
    "lint": "biome check .",
    "typecheck": "bunx tsc --noEmit"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "hono": "^4.6.0",
    "ws": "^8.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/bun": "latest",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.0"
  }
}
