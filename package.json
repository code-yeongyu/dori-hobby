{
  "name": "dori-hobby-web-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:client": "bun run scripts/build-client.ts",
    "build": "bun run build:client && bun run tsc --noEmit",
    "dev": "bun --watch src/server/index.ts",
    "start": "bun src/server/index.ts",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "check": "bun run build && bun run test"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41",
    "hono": "^4.8.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.54.2",
    "@types/bun": "^1.2.20",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.8",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
